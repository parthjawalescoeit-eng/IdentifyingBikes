<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Bikewale Suite">
    <listeners>
        <listener class-name="org.automation.utility.ExtentReportManager"/>
    </listeners>

    <parameter name="browser" value="chrome" />

    <test name="Dropdown and Form Validation Tests">
        <classes>
            <class name="testcases.TC_11_YouTube_navigation_check" />
            <class name="testcases.TC_12_Brochure_Download_Check" />
            <class name="testcases.TC_13_Breadcrumb_Working_Check" />
            <class name="testcases.TC_14_Browser_Navigation_Check" />
            <class name="testcases.TC_15_Search_Electric_Bikes" />
        </classes>
    </test>

</suite>